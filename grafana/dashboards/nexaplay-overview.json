{
  "title": "NexaPlay Server Health",
  "uid": "nexaplay-overview",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Players",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "nexaplay_active_players",
          "legendFormat": "Active Players",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "green", "value": 600 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Request Rate (per second)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{endpoint}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~'5..'}[1m]) / rate(http_requests_total[1m]) * 100",
          "legendFormat": "Error Rate %",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "CPU Usage (%)",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 8, "w": 18, "h": 8 },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{job='node-exporter',mode='idle'}[1m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Memory Usage (MB) — Last Hour",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "timeFrom": "1h",
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job='nexaplay-app'} / 1024 / 1024",
          "legendFormat": "RSS Memory (MB)",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "megabytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 400 }
            ]
          }
        }
      }
    }
  ]
}
